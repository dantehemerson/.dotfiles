// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "edit_predictions": {
    "open_ai_compatible_api": {
      "api_url": "https://opencode.ai/zen/v1/chat/completions",
      "model": "kimi-k2.6"
    },
    "provider": "zed",
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "default_profile": "write",
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "provider": "opencode",
      "model": "go/kimi-k2.6",
      "enable_thinking": false,
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "tabs": {
    "file_icons": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "buffer_font_weight": 400.0,
  "terminal": {
    "font_size": 12.0,
    "font_weight": 300.0,
    "font_family": "SF Mono",
  },
  "colorize_brackets": true,
  "buffer_line_height": {
    "custom": 1.45,
  },
  "buffer_font_family": "Liga Comic Mono",
  "which_key": {
    "enabled": true,
  },
  "icon_theme": {
    "mode": "light",
    "light": "VSCode Icons for Zed (Dark)",
    "dark": "VSCode Icons for Zed (Dark)",
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "relative_line_numbers": "enabled",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "soft_wrap": "editor_width",
  "base_keymap": "VSCode",
  "ui_font_size": 15.0,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "Everforest Light Soft (blur)",
    "dark": "Shades Of Purple",
  },
}
